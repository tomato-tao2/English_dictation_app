# 复制为 /etc/systemd/system/dictation-web.service 后按需改路径与用户：
#   sudo cp scripts/dictation-web.service.example /etc/systemd/system/dictation-web.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now dictation-web
#
# 日志：journalctl -u dictation-web -f

[Unit]
Description=英语单词听写 Web (Flask + Gunicorn)
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/dictation-web
Environment=FLASK_HOST=0.0.0.0
Environment=FLASK_PORT=5000
Environment=GUNICORN_WORKERS=2
# Environment=DICTATION_WEB_PASSWORD=请改为强密码
ExecStart=/opt/dictation-web/.venv/bin/gunicorn --chdir /opt/dictation-web -w 2 -b 0.0.0.0:5000 --timeout 120 web_app:app
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
